{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Question Debt",
  "description": "런 단위의 Question Debt 수합 파일",
  "type": "object",
  "required": ["run_id", "debts"],
  "properties": {
    "run_id": {
      "type": "string",
      "pattern": "^run-\\d{8}-\\d{6}$",
      "description": "런 식별자. run-YYYYMMDD-HHmmss 형식"
    },
    "debts": {
      "type": "array",
      "items": { "$ref": "#/$defs/debt" }
    }
  },
  "$defs": {
    "debt": {
      "type": "object",
      "required": ["id", "run_id", "task_id", "type", "blocking", "status", "title", "question_for_user", "why_it_matters", "impact_scope", "confidence", "soft_criteria"],
      "properties": {
        "confidence_source": {
          "type": "string",
          "enum": ["metis", "planner", "appdev", "backenddev", "designer", "critic", "verifier", "momus"],
          "description": "이 debt를 분류한 에이전트. v2 §3.2 신규 필드"
        },
        "classifier_rationale": {
          "type": "string",
          "description": "분류 근거. 예: 'Goal=0.3, Constraints=0.5, Criteria=0.2 → 가중합 0.34. soft 임계 0.35 미만이므로 soft.'"
        },
        "disputed_by": {
          "type": "array",
          "items": { "type": "string" },
          "description": "분류에 이의를 제기한 에이전트 목록 (예: critic이 Metis 분류를 의심하는 경우)"
        },
        "id": {
          "type": "string",
          "pattern": "^qd-\\d{3,}$",
          "description": "Debt 식별자. qd-001 형식"
        },
        "run_id": {
          "type": "string"
        },
        "task_id": {
          "type": "string",
          "description": "이 debt가 발생한 태스크 ID"
        },
        "type": {
          "type": "string",
          "enum": ["business", "technical", "design", "scope"],
          "description": "모호함의 성격"
        },
        "blocking": {
          "type": "string",
          "enum": ["soft", "hard"],
          "description": "soft: 가정 후 진행 가능. hard: 해당 태스크 블록"
        },
        "status": {
          "type": "string",
          "enum": ["assumed", "blocked", "resolved", "invalidated"],
          "description": "assumed: 가정 채택. blocked: 진행 불가. resolved: 사용자 확인 완료. invalidated: 더 이상 유효하지 않음"
        },
        "title": {
          "type": "string",
          "description": "모호한 지점의 짧은 제목"
        },
        "question_for_user": {
          "type": "string",
          "description": "사용자에게 물어볼 질문"
        },
        "provisional_assumption": {
          "type": ["string", "null"],
          "description": "soft인 경우 채택한 가정. hard이면 null"
        },
        "why_it_matters": {
          "type": "string",
          "description": "이 모호함이 왜 중요한지"
        },
        "impact_scope": {
          "type": "array",
          "items": { "type": "string" },
          "description": "영향 받는 영역 목록"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "가정의 신뢰도 (0~1). soft에서만 유의미"
        },
        "soft_criteria": {
          "type": "object",
          "required": ["has_reasonable_default", "impact_contained_to_task"],
          "properties": {
            "has_reasonable_default": {
              "type": "boolean",
              "description": "합리적 기본값이 존재하는가?"
            },
            "impact_contained_to_task": {
              "type": "boolean",
              "description": "틀려도 해당 태스크만 수정하면 되는가?"
            }
          },
          "description": "둘 다 true여야 soft. 하나라도 false면 hard"
        }
      }
    }
  }
}
