{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Plan",
  "description": "런 단위의 태스크 분해 계획",
  "type": "object",
  "required": ["run_id", "goal", "tasks"],
  "properties": {
    "run_id": {
      "type": "string",
      "pattern": "^run-\\d{8}-\\d{6}$"
    },
    "goal": {
      "type": "string",
      "description": "이 런의 최종 목표"
    },
    "tasks": {
      "type": "array",
      "items": { "$ref": "#/$defs/plan_task" }
    }
  },
  "$defs": {
    "plan_task": {
      "type": "object",
      "required": ["id", "assignee", "title", "category"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^task-\\d{3,}$"
        },
        "assignee": {
          "type": "string",
          "enum": ["metis", "momus", "planner", "appdev", "backenddev", "designer", "critic", "verifier"],
          "description": "담당 에이전트. metis/momus는 분류·검수 레이어 (v2 §2.2/§2.3)"
        },
        "category": {
          "type": "string",
          "enum": ["triage", "plan-review", "plan", "quick", "deep", "visual", "verify", "review"],
          "description": "작업 카테고리. 카테고리→에이전트/모델 라우팅 (v2 §2.5.1). deep은 단일 태스크가 아니라 depends_on으로 분해된 태스크 체인을 의미"
        },
        "title": {
          "type": "string",
          "description": "태스크 제목"
        },
        "description": {
          "type": "string",
          "description": "태스크 상세 설명 (선택)"
        },
        "depends_on": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "선행 태스크 ID 목록"
        }
      }
    }
  }
}
