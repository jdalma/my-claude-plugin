{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Tasks",
  "description": "런 단위의 태스크 목록과 상태",
  "type": "object",
  "required": ["run_id", "tasks"],
  "properties": {
    "run_id": {
      "type": "string",
      "pattern": "^run-\\d{8}-\\d{6}$"
    },
    "tasks": {
      "type": "array",
      "items": { "$ref": "#/$defs/task" }
    }
  },
  "$defs": {
    "task": {
      "type": "object",
      "required": ["id", "assignee", "title", "status", "depends_on", "category"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^task-\\d{3,}$",
          "description": "태스크 식별자. task-001 형식"
        },
        "assignee": {
          "type": "string",
          "enum": ["metis", "momus", "planner", "appdev", "backenddev", "designer", "critic", "verifier"],
          "description": "담당 에이전트"
        },
        "category": {
          "type": "string",
          "enum": ["triage", "plan-review", "plan", "quick", "deep", "visual", "verify", "review"],
          "description": "작업 카테고리. 카테고리→에이전트/모델 라우팅 (v2 §2.5.1)"
        },
        "title": {
          "type": "string",
          "description": "태스크 제목"
        },
        "status": {
          "type": "string",
          "enum": ["NEW", "READY", "RUNNING", "REVIEW", "DONE", "HARD_BLOCKED"],
          "description": "태스크 상태"
        },
        "depends_on": {
          "type": "array",
          "items": { "type": "string" },
          "description": "선행 태스크 ID 목록"
        },
        "result_file": {
          "type": ["string", "null"],
          "description": "에이전트 결과 파일 경로. 완료 후 Lead가 기록"
        },
        "failure_reason": {
          "type": ["string", "null"],
          "description": "HARD_BLOCKED 상태일 때 사유. v2 §6.5 실패 복구 정책 참조"
        }
      }
    }
  }
}
