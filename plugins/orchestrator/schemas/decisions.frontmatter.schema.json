{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Decisions Markdown Frontmatter",
  "description": "decisions.md 파일은 markdown이지만 헤더 메타데이터를 검증 (v2 §4.1)",
  "type": "object",
  "required": ["run_id", "last_updated", "current_phase", "current_run_state"],
  "properties": {
    "run_id": {
      "type": "string",
      "pattern": "^run-\\d{8}-\\d{6}(-\\d+)?$"
    },
    "last_updated": {
      "type": "string",
      "format": "date-time"
    },
    "current_phase": {
      "type": "string",
      "enum": ["triage", "research", "synthesis", "plan-review", "implementation", "verification", "reporting"]
    },
    "current_run_state": {
      "type": "string",
      "enum": ["NEW", "PLANNING", "EXECUTING", "PARTIAL_BLOCKED", "REVIEWING", "PUBLISHING", "WAITING_USER", "DONE"]
    },
    "open_questions": {
      "type": "integer",
      "minimum": 0
    },
    "answer_format_hint": {
      "type": "string",
      "default": "Q1: 2, Q2: a, Q3: 보류"
    }
  }
}
